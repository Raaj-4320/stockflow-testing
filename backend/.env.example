NODE_ENV=development
PORT=4000
API_PREFIX=api
API_VERSION=v1
SECURITY_ENABLE_CORS=true
AUTH_REQUIRED=true
AUTH_DEV_STATIC_TOKEN=dev-static-token
AUTH_DEV_ACTOR_ID=dev-owner
AUTH_DEV_DEFAULT_STORE_ID=dev-store
AUTH_DEV_VERIFIED=true
AUTH_TOKEN_TTL_SECONDS=3600
FEATURE_FLAG_PRODUCTS_ENABLED=false
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=stockflow
MONGODB_APP_NAME=stockflow-backend
MONGODB_MIN_POOL_SIZE=1
MONGODB_MAX_POOL_SIZE=10
MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000
MONGODB_SOCKET_TIMEOUT_MS=20000
