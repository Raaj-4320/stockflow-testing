{
  "security_rules_summary": {
    "users_doc": "/users/{uid} owner-only read/create/update with immutable identity constraints",
    "stores_doc": "/stores/{uid} and nested subcollections owner-only and email-verified",
    "default": "deny all other paths"
  },
  "root_documents": [
    {
      "path": "users/{uid}",
      "key_fields": [
        "uid",
        "email",
        "name",
        "createdAt"
      ],
      "writer_functions": [
        "services/auth.register",
        "services/auth.login (bootstrap if missing)"
      ],
      "reader_functions": [
        "services/auth.login"
      ]
    },
    {
      "path": "stores/{uid}",
      "key_fields": [
        "profile",
        "categories",
        "upfrontOrders",
        "cashSessions",
        "expenses",
        "freightInquiries",
        "freightConfirmedOrders",
        "freightPurchases",
        "purchaseOrders",
        "migrationMarkers"
      ],
      "writer_functions": [
        "services/storage.saveData",
        "services/storage.syncToCloud",
        "services/storage.ensureStoreInitializedForCurrentUser"
      ],
      "reader_functions": [
        "services/storage.syncFromCloud"
      ]
    }
  ],
  "subcollections": [
    {
      "path": "stores/{uid}/products/{productId}",
      "key_fields": [
        "id",
        "name",
        "barcode",
        "stock",
        "stockByVariantColor",
        "buyPrice",
        "sellPrice",
        "category"
      ],
      "writer_functions": [
        "addProduct",
        "updateProduct",
        "deleteProductInSubcollection",
        "receivePurchaseOrder"
      ],
      "reader_functions": [
        "syncFromCloud product listener",
        "readProductsFromSubcollection"
      ]
    },
    {
      "path": "stores/{uid}/customers/{customerId}",
      "key_fields": [
        "id",
        "name",
        "phone",
        "totalSpend",
        "totalDue",
        "storeCredit"
      ],
      "writer_functions": [
        "addCustomer",
        "updateCustomer",
        "deleteCustomerInSubcollection",
        "processTransaction"
      ],
      "reader_functions": [
        "syncFromCloud customer listener",
        "readCustomersFromSubcollection"
      ]
    },
    {
      "path": "stores/{uid}/transactions/{txId}",
      "key_fields": [
        "id",
        "type",
        "items",
        "total",
        "paymentMethod",
        "saleSettlement",
        "returnHandlingMode",
        "customerId"
      ],
      "writer_functions": [
        "processTransaction",
        "addHistoricalTransactions",
        "updateTransaction",
        "deleteTransactionAndReconcileInSubcollection"
      ],
      "reader_functions": [
        "syncFromCloud transaction listener",
        "readTransactionsFromSubcollection"
      ]
    },
    {
      "path": "stores/{uid}/deletedTransactions/{recordId}",
      "key_fields": [
        "originalTransactionId",
        "deletedAt",
        "deleteReason",
        "beforeImpact",
        "afterImpact"
      ],
      "writer_functions": [
        "deleteTransaction",
        "deleteTransactionAndReconcileInSubcollection"
      ],
      "reader_functions": [
        "syncFromCloud deleted listener",
        "readDeletedTransactionsFromSubcollection"
      ]
    },
    {
      "path": "stores/{uid}/auditEvents/{eventId}",
      "key_fields": [
        "operation",
        "actorUid",
        "actorEmail",
        "createdAt",
        "context"
      ],
      "writer_functions": [
        "writeAuditEvent"
      ],
      "reader_functions": [
        "none in UI"
      ]
    },
    {
      "path": "stores/{uid}/operationCommits/{commitId}",
      "key_fields": [
        "type",
        "status",
        "entityRefs",
        "payloadVersion"
      ],
      "writer_functions": [
        "commitProcessTransactionAtomically"
      ],
      "reader_functions": [
        "none in UI"
      ]
    },
    {
      "path": "stores/{uid}/customerProductStats/{customerId_productId}",
      "key_fields": [
        "customerId",
        "productId",
        "soldQty",
        "returnedQty",
        "updatedAt"
      ],
      "writer_functions": [
        "processTransaction path",
        "scripts/backfill-customer-product-stats.js"
      ],
      "reader_functions": [
        "scripts/verify-customer-product-stats-backfill.js"
      ]
    }
  ],
  "derived_fields": [
    "customer.totalDue and customer.storeCredit normalized via canonical allocation helpers",
    "transaction.saleSettlement derived from payment mode and store credit use",
    "finance snapshots and cashbook rollups derived in services/storage and pages/Finance"
  ],
  "legacy_schema_variants": [
    "top-level products collection used by migration scripts",
    "stores/{uid}.products array used by migration scripts"
  ],
  "migration_assumptions": [
    "entity data moved from root arrays to per-entity subcollections",
    "customerProductStats backfill marker version v1 and strictModeEnabled expected",
    "image provider migration from Firebase Storage URLs to Cloudinary URLs"
  ]
}